[TEMPLATE]
# ============================================================
# DiabetesCare — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
#
# Para deploy na Vercel, configure estas variáveis no painel:
# https://vercel.com/seu-projeto/settings/environment-variables
#
# Para desenvolvimento local:
#   cp .env.example .env.local
#   # Edite .env.local com seus valores
# ============================================================

# ── Supabase (Obrigatório) ──────────────────────────────────
# Crie um projeto em https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=

# ── E-mail / SMTP (Obrigatório para recuperação de senha) ──
# Suporta SMTP genérico ou Gmail.
# Se SMTP_HOST não for definido, usa o service "gmail".
#
# Para Gmail:
#   1. Ative 2FA em https://myaccount.google.com/security
#   2. Gere uma "Senha de App" em https://myaccount.google.com/apppasswords
#   3. Use seu email como EMAIL_USER e a senha de app como EMAIL_PASS
#
# Para Vercel (recomendado):
#   Use um serviço SMTP como SendGrid, Mailgun, ou o próprio Gmail SMTP
#   Exemplo com Gmail SMTP:
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#   Timeout configurado para 10s (limite da Vercel Hobby)
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=suasenhadeapp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── URL do Frontend (usada no link de reset do e-mail) ─────
# Em produção (Vercel), use a URL do seu domínio:
# Ex: FRONTEND_URL=https://diabetescare.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Diabetica IA — Opção Fácil (Groq) ──────────────────────
# Crie uma chave grátis em https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Diabetica IA — Opção Avançada (Servidor Python) ────────
# Rode o servidor Python localmente ou em um serviço de nuvem
DIABETICA_API_URL=http://localhost:5000/predict
