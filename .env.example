# Supabase / Auth (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=

# E-mail (obrigatório para recuperação de senha)
# Suporta SMTP genérico ou Gmail.
# Se SMTP_HOST não for definido, usa o service "gmail".
# Para Gmail: use uma Senha de App (App Password) com 2FA ativado.
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=suasenhadeapp
SMTP_HOST=
SMTP_PORT=587

# URL do frontend (usada no link de reset do e-mail)
FRONTEND_URL=http://localhost:3000

# API Diabetica — opção fácil (produção na Vercel, sem Python)
# Crie uma chave grátis em https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# API Diabetica — opção avançada (servidor Python local ou na nuvem)
DIABETICA_API_URL=http://localhost:5000/predict
